# .env.example - СКОПИРУЙ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИ СВОИМИ ДАННЫМИ
# App
APP_NAME="AI Course Platform"
DEBUG=False
SECRET_KEY=your-secret-key-here
BOT_USERNAME=your_bot_username
SITE_URL=https://davydovaai.ru  # ← ТВОЙ ДОМЕН!

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aicourse

# Telegram
BOT_TOKEN=your-telegram-bot-token

# YooKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Kinescope
KINESCOPE_API_KEY=your-api-key
KINESCOPE_PROJECT_ID=your-project-id

# Admin
ADMIN_SECRET_CODE=your-admin-secret-code

# Redis
REDIS_URL=redis://localhost:6379/0